# ─────────────────────────────────────────────────────────
#  AVIORA — Docker Compose maxfiy qiymatlari (NAMUNA)
#  Bu faylni serverda `.env` ga nusxalang va qiymatlarni to'ldiring:
#     cp .env.docker.example .env   (so'ng tahrirlang)
#  `.env` git'ga KOMMIT QILINMAYDI (.gitignore'da). docker-compose uni
#  avtomatik o'qiydi va ${VAR} larni shu yerdan oladi.
#  Yangi kalit generatsiya: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────

# Postgres paroli (kuchli, tasodifiy bo'lsin)
POSTGRES_PASSWORD=change-me-strong-db-password

# JWT imzo kalitlari (har biri 64 belgili hex tavsiya etiladi)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Frontend manzili (CORS) — odatda production domeni
CORS_ORIGIN=https://avioraerp.asosit.uz

# Seed superadmin/test paroli
SEED_DEFAULT_PASSWORD=change-me-seed-password
