# ─────────────────────────────────────────────────────────
#  AVIORA BOSHQARUV — Environment namuna
#  Bu faylni `backend/.env` ga nusxalang va qiymatlarni to'ldiring.
# ─────────────────────────────────────────────────────────

# ── Database (Neon / Supabase / lokal Postgres) ──
# Neon namunasi:    postgresql://USER:PASS@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require
# Supabase namunasi: postgresql://postgres:PASS@db.xxx.supabase.co:5432/postgres
# Lokal namunasi:    postgresql://postgres:postgres@localhost:5432/aviora?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/aviora?sslmode=require"

# ── JWT ──
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── App ──
PORT=3000
NODE_ENV=development
# Frontend manzili (CORS uchun)
CORS_ORIGIN="http://localhost:5173"

# ── File storage (MVP: lokal) ──
UPLOAD_DIR="uploads"

# ── Seed (test superadmin paroli) ──
SEED_DEFAULT_PASSWORD="Aviora2026!"

# ── Google Meet / Calendar integratsiyasi (ixtiyoriy) ──
# Yig'ilish "Havolasi" bo'sh qoldirilsa, tizim avtomatik Google Meet havolasi yaratadi.
# Maxfiy kalitlar FAQAT shu yerda (.env) — kodda hardcode YO'Q.
# MUHIM: OAuth consent screen "In production" bo'lsa refresh token ESKIRMAYDI (barqaror).
#        "Testing" rejimida token har 7 kunda eskiradi.
# Token olish: OAuth Playground (https://developers.google.com/oauthplayground) yoki backend/scripts/google-oauth.js
GOOGLE_CLIENT_ID="571124877992-xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxx"
GOOGLE_REDIRECT_URI="https://developers.google.com/oauthplayground"
GOOGLE_REFRESH_TOKEN="1//04xxxx"
GOOGLE_CALENDAR_ID="primary"
GOOGLE_MEET_TIMEZONE="Asia/Tashkent"
