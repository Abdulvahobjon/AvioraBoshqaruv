# Backend API manzili (oxirida "/" YO'Q — kod o'zi /api, /uploads, /socket.io qo'shadi)
#
# Lokal (npm run dev):  bo'sh qoldiring — Vite proxy /api -> localhost:3000 ishlatadi
#   VITE_API_URL=
#
# Production (bitta domen):  frontend va backend bir domenda, API /api path orqali
#   VITE_API_URL=https://avioraerp.asosit.uz
#
# Eslatma: Docker bilan deploy qilganda bu qiymat docker-compose.yml dagi
# frontend > build > args > VITE_API_URL dan olinadi (build vaqtida baked bo'ladi).
VITE_API_URL=
