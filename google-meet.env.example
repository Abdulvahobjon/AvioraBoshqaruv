# ─────────────────────────────────────────────────────────
#  Google Meet (Calendar API) — PRODUCTION sirlari
#  Bu NAMUNA fayl. Serverda nusxa oling va haqiqiy qiymatlar bilan to'ldiring:
#      cp google-meet.env.example google-meet.env
#  So'ng:  docker compose up -d --build
#
#  Haqiqiy `google-meet.env` git'ga kommit QILINMAYDI (.gitignore'da).
#  Qiymatlarni lokal `backend/.env` faylidan ko'chirib oling.
# ─────────────────────────────────────────────────────────

# OAuth client (Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID="571124877992-xxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxx"

# Refresh token (backend/scripts/google-oauth.js natijasidan).
# asositllm@gmail.com akkaunti — barcha Meet havolalari shu kalendarda yaratiladi.
GOOGLE_REFRESH_TOKEN_ASOSITLLM="1//0xxxxxxxx"

# Vaqt mintaqasi (ixtiyoriy, standart Asia/Tashkent)
GOOGLE_TIMEZONE="Asia/Tashkent"

# DIQQAT: GOOGLE_REDIRECT_URI bu yerda SHART EMAS.
# U faqat token olish jarayonida (google-oauth.js) ishlatiladi; runtime'da
# refresh_token bilan access-token yangilashda redirect URI yuborilmaydi.
