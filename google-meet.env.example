# ─────────────────────────────────────────────────────────
#  Google Meet / Calendar — PRODUCTION sirlari
#  Bu NAMUNA fayl. Serverda nusxa oling va haqiqiy qiymatlar bilan to'ldiring:
#      cp google-meet.env.example google-meet.env
#  So'ng:  docker compose up -d --build
#
#  Haqiqiy `google-meet.env` git'ga kommit QILINMAYDI (.gitignore'da).
#  Qiymatlarni lokal `backend/.env` faylidan ko'chirib oling.
# ─────────────────────────────────────────────────────────

# OAuth client (Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID="571124877992-xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxx"

# OAuth Playground orqali token olinsa shu redirect ishlatiladi.
# (Runtime'da refresh paytida redirect yuborilmaydi — token olish uchungina kerak.)
GOOGLE_REDIRECT_URI="https://developers.google.com/oauthplayground"

# Refresh token. MUHIM: consent screen "In production" bo'lsa eskirmaydi.
GOOGLE_REFRESH_TOKEN="1//04xxxx"

# Kalendar va vaqt mintaqasi
GOOGLE_CALENDAR_ID="primary"
GOOGLE_MEET_TIMEZONE="Asia/Tashkent"
